<?xml version="1.0" encoding="UTF-8"?>
<!--
    Mapping DESC_QUALI → categoria raggruppata.
    Solo le sigle contrattuali illeggibili vengono raggruppate.
    Tutte le qualifiche non elencate passano invariate col valore originale.
    Il primo prefisso che matcha (startswith) vince.
-->
<mapping_qualifiche>
    <!-- Dirigenti Medici (tutte le varianti contrattuali) -->
    <regola prefisso="DIR. MED"          categoria="DIRIGENTE MEDICO"/>
    <regola prefisso="DIR.MED"           categoria="DIRIGENTE MEDICO"/>
    <regola prefisso="DIRG. MED"         categoria="DIRIGENTE MEDICO"/>
    <regola prefisso="DIRIG. MED"        categoria="DIRIGENTE MEDICO"/>
    <regola prefisso="DIRIG. I LIV"      categoria="DIRIGENTE MEDICO"/>
    <regola prefisso="DIRIGENTE MEDICO"  categoria="DIRIGENTE MEDICO"/>

    <!-- Dirigenti Veterinari -->
    <regola prefisso="DIR. VETER"        categoria="DIRIGENTE VETERINARIO"/>
    <regola prefisso="DIR.VETER"         categoria="DIRIGENTE VETERINARIO"/>
    <regola prefisso="DIRIG. VETER"      categoria="DIRIGENTE VETERINARIO"/>
    <regola prefisso="VETERINARIO"       categoria="DIRIGENTE VETERINARIO"/>

    <!-- Dirigenti Amministrativi -->
