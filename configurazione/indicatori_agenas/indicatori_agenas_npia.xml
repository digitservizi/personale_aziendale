<?xml version="1.0" encoding="UTF-8"?>
<!--
  Standard AGENAS – Area Neuropsichiatria Infanzia e Adolescenza (NPIA)
  Fonte: Documento AGENAS assistenza territoriale
  Dotazione minima per 10.000 abitanti target 1-17 anni
  Servizio territoriale ogni 150.000-250.000 abitanti
-->
<indicatori_agenas_npia>
  <parametri>
    <base_popolazione>10000</base_popolazione>
    <fascia_popolazione>range_1_17</fascia_popolazione>
    <titolo>AREA NEUROPSICHIATRIA INFANZIA E ADOLESCENZA (NPIA)</titolo>
    <riferimento>Documento AGENAS servizi territoriali – Standard NPIA</riferimento>
  </parametri>

  <unita_operative>
    <uo pattern="NEUROPSICH"/>
  </unita_operative>

  <profili>
    <profilo nome="Dirigenza Sanitaria" tasso="6.0"
             nota="Medici NPI + psicologi psicoterapeuti">
      <mappa qualifica="DIRIGENTE MEDICO"/>
      <mappa qualifica="DIRIGENTE PSICOLOGO"/>
    </profilo>
    <profilo nome="Prof. Sanitarie + Ass. Sociali" tasso="10.0"
             nota="TNPEE, educatore/TdRP, infermiere, fisioterapista, assistenti sociali">
      <mappa qualifica="INFERMIERE"/>
      <mappa qualifica="TECNICO NEURO-PSICOMOTRICISTA"/>
      <mappa qualifica="EDUCATORE PROFESSIONALE"/>
      <mappa qualifica="TECNICO DELLA RIAB.PSICHIATRICA"/>
      <mappa qualifica="FISIOTERAPISTA"/>
      <mappa qualifica="LOGOPEDISTA"/>
      <mappa qualifica="ASSISTENTE SOCIALE"/>
    </profilo>
    <profilo nome="Altro Personale" tasso="0.2"
             nota="Incluso personale amministrativo">
      <mappa qualifica="COLLABORATORE AMMINISTRATIVO"/>
      <mappa qualifica="ASSISTENTE AMMINISTRATIVO"/>
      <mappa qualifica="OPERATORE TECNICO"/>
    </profilo>
  </profili>
</indicatori_agenas_npia>
