<?xml version="1.0" encoding="UTF-8"?>
<!--
  Standard AGENAS – Salute in Carcere
  Fonte: Documento AGENAS, standard minimi servizi Salute in Carcere
  + standard SerD per dipendenze in carcere
  Tassi calcolati per 350 detenuti
  SM: 1 medico + 1 psicologo + 1 prof. sanitario / 350 detenuti
  SerD: 1 medico + 1 psicologo + 1 ass. sociale + 1 altra figura / 350 detenuti
-->
<indicatori_agenas_carcere>
  <parametri>
    <base_popolazione>350</base_popolazione>
    <fascia_popolazione>detenuti</fascia_popolazione>
    <titolo>AREA SALUTE IN CARCERE</titolo>
    <riferimento>Standard minimi AGENAS – Servizi Salute in Carcere e SerD penitenziario</riferimento>
  </parametri>

  <unita_operative>
    <uo pattern="DETENUTI"/>
    <uo pattern="CARCER"/>
    <uo pattern="PENITEN"/>
  </unita_operative>

  <profili>
    <profilo nome="Medici" tasso="2.0"
             nota="SM + SerD: 1+1 medici ogni 350 detenuti">
      <mappa qualifica="DIRIGENTE MEDICO"/>
    </profilo>
    <profilo nome="Psicologi" tasso="2.0"
             nota="SM + SerD: 1+1 psicologi ogni 350 detenuti">
      <mappa qualifica="DIRIGENTE PSICOLOGO"/>
    </profilo>
    <profilo nome="Infermieri" tasso="1.0"
             nota="SM: 1 prof. sanitario ogni 350 detenuti">
      <mappa qualifica="INFERMIERE"/>
    </profilo>
    <profilo nome="Assistenti Sociali" tasso="1.0"
             nota="SerD: 1 assistente sociale ogni 350 detenuti">
      <mappa qualifica="ASSISTENTE SOCIALE"/>
    </profilo>
  </profili>
</indicatori_agenas_carcere>
