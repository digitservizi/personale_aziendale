<!--
  INDICATORI FABBISOGNO OSPEDALI DI COMUNITÀ - DM 77/2022
  
  Il fabbisogno di personale per gli Ospedali di Comunità (OdC) è definito
  dal DM 77/2022 e NON segue il metodo di calcolo ospedaliero basato su
  posti letto, intensità e coefficienti di complessità.
  
  Il DM 77 stabilisce un numero fisso di unità per ciascun OdC,
  indipendentemente dal numero di posti letto.

  Ogni <figura> contiene:
    - profilo:  nome della categoria DM 77 (usato come etichetta nel report)
    - unita:    numero di unità fabbisogno per OdC
    - profili_raggruppati: elenco dei PROFILO_RAGGRUPPATO del DB che
      ricadono in questa categoria (quelli generati da profili_atto_aziendale.xml).
      Se assente, il match avviene per nome esatto (profilo == PROFILO_RAGGRUPPATO).
-->
<FabbisognoOdC fonte="DM 77/2022">

  <figura>
    <profilo>PROFESSIONI SANITARIE INFERMIERISTICHE</profilo>
    <unita>7</unita>
    <profili_raggruppati>
      <!-- PROFILO_RAGGRUPPATO da profili_atto_aziendale.xml -->
      <voce>INFERMIERI</voce>
    </profili_raggruppati>
  </figura>

  <figura>
    <profilo>OPERATORE SOCIO SANITARIO</profilo>
    <unita>4</unita>
    <profili_raggruppati>
      <!-- PROFILO_RAGGRUPPATO da profili_atto_aziendale.xml -->
      <voce>OSS</voce>
    </profili_raggruppati>
  </figura>

  <figura>
    <profilo>PROFESSIONI SANITARIE DELLA RIABILITAZIONE</profilo>
    <unita>1</unita>
    <profili_raggruppati>
      <!-- PROFILO_RAGGRUPPATO da profili_atto_aziendale.xml -->
      <voce>FISIOTERAPISTI</voce>
      <voce>LOGOPEDISTI</voce>
      <voce>TERAPISTI OCCUPAZIONALI</voce>
      <voce>TECNICO DELLA RIABILITAZIONE PSICHIATRICA</voce>
      <voce>NEUROPSICOMOTRICISTI</voce>
    </profili_raggruppati>
  </figura>

  <figura>
