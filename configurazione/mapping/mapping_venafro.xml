<?xml version="1.0" encoding="UTF-8"?>
<!--
  MAPPING OSPEDALE DI COMUNITÀ - VENAFRO
  Definisce le strutture degenziali dell'OdC di Venafro,
  identificate tramite la colonna DESC_TIPO_CDC del database personale.

  Ogni <struttura>:
    - nome:             nome descrittivo della struttura
    - pattern_cdc:      regex da cercare in DESC_TIPO_CDC (case-insensitive)
    - tipo_sede:        valore atteso in DESC_TIPO_SEDE
    - sede_fisica:      valore atteso in DESC_SEDE_FISICA
    - posti_letto:      posti letto della struttura (da compilare)
    - intensita:        livello di intensità assistenziale
    - note:             eventuali annotazioni
-->
<OspedaleComunita nome="Venafro">

  <struttura>
    <nome>OdC Venafro - U.D.I.</nome>
    <pattern_cdc>OSP. COMUNITA.*VENAFRO.*U\.?D\.?I</pattern_cdc>
    <tipo_sede>DISTRETTO SANITARIO VENAFRO</tipo_sede>
    <sede_fisica>ISERNIA - VENAFRO</sede_fisica>
    <posti_letto>
      <ordinari>20</ordinari>
      <dh>0</dh>
      <ds>0</ds>
    </posti_letto>
    <intensita>Bassa</intensita>
    <note>Unità Degenza Infermieristica - Ospedale di Comunità</note>
  </struttura>

  <struttura>
    <nome>RSA Venafro</nome>
    <pattern_cdc>DS IS.*RSA.*VENAFRO</pattern_cdc>
    <tipo_sede>DISTRETTO SANITARIO VENAFRO</tipo_sede>
    <sede_fisica>ISERNIA - VENAFRO</sede_fisica>
    <posti_letto>
      <ordinari>20</ordinari>
      <dh>0</dh>
      <ds>0</ds>
    </posti_letto>
    <intensita>Bassa</intensita>
    <note>Residenza Sanitaria Assistenziale</note>
  </struttura>

  <struttura>
    <nome>Riabilitazione ex Art.26 Venafro</nome>
    <pattern_cdc>DS IS.*RIABILITAZIONE.*EX ART</pattern_cdc>
    <tipo_sede>DISTRETTO SANITARIO VENAFRO</tipo_sede>
    <sede_fisica>ISERNIA - VENAFRO</sede_fisica>
    <posti_letto>
      <ordinari>0</ordinari>
      <dh>0</dh>
      <ds>0</ds>
    </posti_letto>
    <intensita>Bassa</intensita>
    <note>Riabilitazione extraospedaliera a ciclo continuo</note>
  </struttura>

</OspedaleComunita>
