<?xml version="1.0" encoding="UTF-8"?>
<!--
  Standard AGENAS – Area Salute Mentale Adulti (Livelli 1 e 2)
  Fonte: DPR 1/11/1999, documento AGENAS assistenza territoriale
  Dotazione minima per 10.000 abitanti >= 18 anni
  Totale minimo: >= 6,7 operatori / 10.000 ab. >= 18 anni
-->
<indicatori_agenas_salute_mentale>
  <parametri>
    <base_popolazione>10000</base_popolazione>
    <fascia_popolazione>gte_18</fascia_popolazione>
    <titolo>AREA SALUTE MENTALE ADULTI</titolo>
    <riferimento>DPR 1/11/99, documento AGENAS servizi territoriali</riferimento>
  </parametri>

  <unita_operative>
    <uo pattern="CSM"/>
    <uo pattern="SPDC"/>
    <uo pattern="SALUTE MENTALE"/>
  </unita_operative>

  <profili>
    <profilo nome="Medici Psichiatri" tasso="1.0">
      <mappa qualifica="DIRIGENTE MEDICO"/>
    </profilo>
    <profilo nome="Psicologi Psicoterapeuti" tasso="0.5">
      <mappa qualifica="DIRIGENTE PSICOLOGO"/>
    </profilo>
    <profilo nome="Prof. Sanitarie + Ass. Sociali" tasso="5.0"
             nota="Infermieri, educatori prof., TRP, assistenti sociali, OSS">
      <mappa qualifica="INFERMIERE"/>
      <mappa qualifica="TECNICO DELLA RIAB.PSICHIATRICA"/>
      <mappa qualifica="ASSISTENTE SOCIALE"/>
      <mappa qualifica="EDUCATORE PROFESSIONALE"/>
      <mappa qualifica="OPERATORE SOCIO SANITARIO"/>
    </profilo>
    <profilo nome="Altro Personale" tasso="0.2"
             nota="Incluso personale amministrativo">
      <mappa qualifica="COLLABORATORE AMMINISTRATIVO"/>
      <mappa qualifica="ASSISTENTE AMMINISTRATIVO"/>
      <mappa qualifica="OPERATORE TECNICO"/>
      <mappa qualifica="COLLABORATORE TECNICO"/>
    </profilo>
  </profili>
</indicatori_agenas_salute_mentale>
